# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Gemini model used for classification and extraction. Any generateContent-capable
# model works. Free-tier quotas are small and per-model: flash-lite has the most
# headroom; gemini-3.5-flash or a pro-tier model gives higher accuracy if your key
# has quota for it.
GEMINI_MODEL=gemini-3.1-flash-lite

# Fields / classifications below this confidence are flagged for human attention.
CONFIDENCE_THRESHOLD=0.75

# Where the Streamlit UI finds the FastAPI backend.
API_BASE_URL=http://127.0.0.1:8010
